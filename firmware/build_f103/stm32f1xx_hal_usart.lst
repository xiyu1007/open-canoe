 787:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         ptxdata16bits++;
 788:./f103/HAL/Src/stm32f1xx_hal_usart.c ****       }
 789:./f103/HAL/Src/stm32f1xx_hal_usart.c ****       else
 790:./f103/HAL/Src/stm32f1xx_hal_usart.c ****       {
 791:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         husart->Instance->DR = (uint8_t)(*ptxdata8bits & (uint8_t)0xFF);
