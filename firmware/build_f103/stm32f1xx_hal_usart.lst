 726:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   */
 727:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 728:./f103/HAL/Src/stm32f1xx_hal_usart.c **** /**
 729:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   * @brief  Simplex Send an amount of data in blocking mode.
 730:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   * @note   When USART parity is not enabled (PCE = 0), and Word Length is configured to 9 bits (M1
 731:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   *         the sent data is handled as a set of u16. In this case, Size must indicate the number
 732:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   *         of u16 provided through pTxData.
 733:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   * @param  husart  Pointer to a USART_HandleTypeDef structure that contains
 734:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   *                 the configuration information for the specified USART module.
 735:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   * @param  pTxData Pointer to data buffer (u8 or u16 data elements).
 736:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   * @param  Size    Amount of data elements (u8 or u16) to be sent.
 737:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   * @param  Timeout Timeout duration.
 738:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   * @retval HAL status
 739:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   */
 740:./f103/HAL/Src/stm32f1xx_hal_usart.c **** HAL_StatusTypeDef HAL_USART_Transmit(USART_HandleTypeDef *husart, const uint8_t *pTxData, uint16_t 
 741:./f103/HAL/Src/stm32f1xx_hal_usart.c **** {
 742:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   const uint8_t  *ptxdata8bits;
 743:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   const uint16_t *ptxdata16bits;
