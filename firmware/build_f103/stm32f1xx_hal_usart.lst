 797:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 798:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     if (USART_WaitOnFlagUntilTimeout(husart, USART_FLAG_TC, RESET, tickstart, Timeout) != HAL_OK)
 799:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     {
 800:./f103/HAL/Src/stm32f1xx_hal_usart.c ****       return HAL_TIMEOUT;
