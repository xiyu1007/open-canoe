 645:./f103/HAL/Src/stm32f1xx_hal_usart.c **** /**
 646:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   * @}
 647:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   */
 648:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 649:./f103/HAL/Src/stm32f1xx_hal_usart.c **** /** @defgroup USART_Exported_Functions_Group2 IO operation functions
 650:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   *  @brief   USART Transmit and Receive functions
 651:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   *
 652:./f103/HAL/Src/stm32f1xx_hal_usart.c **** @verbatim
 653:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   ==============================================================================
 654:./f103/HAL/Src/stm32f1xx_hal_usart.c ****                          ##### IO operation functions #####
 655:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   ==============================================================================
 656:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   [..]
 657:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     This subsection provides a set of functions allowing to manage the USART synchronous
 658:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     data transfers.
 659:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
ARM GAS  C:\WINDOWS\ccnv4A6V.s 			page 13


 660:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   [..]
 661:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     The USART supports master mode only: it cannot receive or send data related to an input
 662:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     clock (SCLK is always an output).
 663:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 664:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     (#) There are two modes of transfer:
 665:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) Blocking mode: The communication is performed in polling mode.
 666:./f103/HAL/Src/stm32f1xx_hal_usart.c ****              The HAL status of all data processing is returned by the same function
 667:./f103/HAL/Src/stm32f1xx_hal_usart.c ****              after finishing transfer.
 668:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) No-Blocking mode: The communication is performed using Interrupts
 669:./f103/HAL/Src/stm32f1xx_hal_usart.c ****              or DMA, These API's return the HAL status.
 670:./f103/HAL/Src/stm32f1xx_hal_usart.c ****              The end of the data processing will be indicated through the
 671:./f103/HAL/Src/stm32f1xx_hal_usart.c ****              dedicated USART IRQ when using Interrupt mode or the DMA IRQ when
 672:./f103/HAL/Src/stm32f1xx_hal_usart.c ****              using DMA mode.
 673:./f103/HAL/Src/stm32f1xx_hal_usart.c ****              The HAL_USART_TxCpltCallback(), HAL_USART_RxCpltCallback() and HAL_USART_TxRxCpltCallb
 674:./f103/HAL/Src/stm32f1xx_hal_usart.c ****               user callbacks
 675:./f103/HAL/Src/stm32f1xx_hal_usart.c ****              will be executed respectively at the end of the transmit or Receive process
 676:./f103/HAL/Src/stm32f1xx_hal_usart.c ****              The HAL_USART_ErrorCallback() user callback will be executed when a communication
 677:./f103/HAL/Src/stm32f1xx_hal_usart.c ****              error is detected
 678:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 679:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     (#) Blocking mode APIs are :
 680:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_Transmit() in simplex mode
 681:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_Receive() in full duplex receive only
 682:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_TransmitReceive() in full duplex mode
 683:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 684:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     (#) Non Blocking mode APIs with Interrupt are :
 685:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_Transmit_IT()in simplex mode
 686:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_Receive_IT() in full duplex receive only
 687:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_TransmitReceive_IT() in full duplex mode
 688:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_IRQHandler()
 689:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 690:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     (#) Non Blocking mode functions with DMA are :
 691:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_Transmit_DMA()in simplex mode
 692:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_Receive_DMA() in full duplex receive only
 693:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_TransmitReceive_DMA() in full duplex mode
 694:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_DMAPause()
 695:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_DMAResume()
 696:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_DMAStop()
 697:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 698:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     (#) A set of Transfer Complete Callbacks are provided in non Blocking mode:
 699:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_TxHalfCpltCallback()
 700:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_TxCpltCallback()
 701:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_RxHalfCpltCallback()
 702:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_RxCpltCallback()
 703:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_ErrorCallback()
 704:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_TxRxCpltCallback()
 705:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 706:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     (#) Non-Blocking mode transfers could be aborted using Abort API's :
 707:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_Abort()
 708:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_Abort_IT()
 709:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 710:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     (#) For Abort services based on interrupts (HAL_USART_Abort_IT), a Abort Complete Callbacks is 
 711:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) HAL_USART_AbortCpltCallback()
 712:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 713:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     (#) In Non-Blocking mode transfers, possible errors are split into 2 categories.
 714:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         Errors are handled as follows :
 715:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) Error is considered as Recoverable and non blocking : Transfer could go till end, but 
 716:./f103/HAL/Src/stm32f1xx_hal_usart.c ****              to be evaluated by user : this concerns Frame Error, Parity Error or Noise Error in In
ARM GAS  C:\WINDOWS\ccnv4A6V.s 			page 14


 717:./f103/HAL/Src/stm32f1xx_hal_usart.c ****              Received character is then retrieved and stored in Rx buffer, Error code is set to all
 718:./f103/HAL/Src/stm32f1xx_hal_usart.c ****              and HAL_USART_ErrorCallback() user callback is executed. Transfer is kept ongoing on U
 719:./f103/HAL/Src/stm32f1xx_hal_usart.c ****              If user wants to abort it, Abort services should be called by user.
 720:./f103/HAL/Src/stm32f1xx_hal_usart.c ****         (++) Error is considered as Blocking : Transfer could not be completed properly and is abor
 721:./f103/HAL/Src/stm32f1xx_hal_usart.c ****              This concerns Overrun Error In Interrupt mode reception and all errors in DMA mode.
 722:./f103/HAL/Src/stm32f1xx_hal_usart.c ****              Error code is set to allow user to identify error type, and HAL_USART_ErrorCallback() 
 723:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 724:./f103/HAL/Src/stm32f1xx_hal_usart.c **** @endverbatim
