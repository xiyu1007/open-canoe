 802:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 803:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     husart->State = HAL_USART_STATE_READY;
 804:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 805:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     /* Process Unlocked */
 806:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     __HAL_UNLOCK(husart);
 807:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
