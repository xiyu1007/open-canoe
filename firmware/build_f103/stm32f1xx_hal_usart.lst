 745:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 746:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   if (husart->State == HAL_USART_STATE_READY)
 747:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   {
 748:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     if ((pTxData == NULL) || (Size == 0))
 749:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     {
 750:./f103/HAL/Src/stm32f1xx_hal_usart.c ****       return  HAL_ERROR;
 751:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     }
 752:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 753:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     /* Process Locked */
 754:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     __HAL_LOCK(husart);
 755:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 756:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     husart->ErrorCode = HAL_USART_ERROR_NONE;
 757:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     husart->State = HAL_USART_STATE_BUSY_TX;
 758:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 759:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     /* Init tickstart for timeout management */
 760:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     tickstart = HAL_GetTick();
 761:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 762:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     husart->TxXferSize = Size;
