2119:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   */
2120:./f103/HAL/Src/stm32f1xx_hal_usart.c **** static void USART_DMATransmitCplt(DMA_HandleTypeDef *hdma)
2121:./f103/HAL/Src/stm32f1xx_hal_usart.c **** {
2122:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   USART_HandleTypeDef *husart = (USART_HandleTypeDef *)((DMA_HandleTypeDef *)hdma)->Parent;
2123:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   /* DMA Normal mode */
2124:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   if ((hdma->Instance->CCR & DMA_CCR_CIRC) == 0U)
2125:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   {
2126:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     husart->TxXferCount = 0U;
2127:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     if (husart->State == HAL_USART_STATE_BUSY_TX)
2128:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     {
2129:./f103/HAL/Src/stm32f1xx_hal_usart.c ****       /* Disable the DMA transfer for transmit request by resetting the DMAT bit
2130:./f103/HAL/Src/stm32f1xx_hal_usart.c ****          in the USART CR3 register */
2131:./f103/HAL/Src/stm32f1xx_hal_usart.c ****       CLEAR_BIT(husart->Instance->CR3, USART_CR3_DMAT);
2132:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
2133:./f103/HAL/Src/stm32f1xx_hal_usart.c ****       /* Enable the USART Transmit Complete Interrupt */
2134:./f103/HAL/Src/stm32f1xx_hal_usart.c ****       SET_BIT(husart->Instance->CR1, USART_CR1_TCIE);
2135:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     }
2136:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   }
2137:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   /* DMA Circular mode */
2138:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   else
2139:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   {
2140:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     if (husart->State == HAL_USART_STATE_BUSY_TX)
2141:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     {
ARM GAS  C:\WINDOWS\ccnv4A6V.s 			page 39


2142:./f103/HAL/Src/stm32f1xx_hal_usart.c **** #if (USE_HAL_USART_REGISTER_CALLBACKS == 1)
2143:./f103/HAL/Src/stm32f1xx_hal_usart.c ****       /* Call registered Tx Complete Callback */
2144:./f103/HAL/Src/stm32f1xx_hal_usart.c ****       husart->TxCpltCallback(husart);
2145:./f103/HAL/Src/stm32f1xx_hal_usart.c **** #else
2146:./f103/HAL/Src/stm32f1xx_hal_usart.c ****       /* Call legacy weak Tx Complete Callback */
