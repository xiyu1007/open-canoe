 290:./f103/HAL/Src/stm32f1xx_hal_usart.c **** /**
 291:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   * @brief  Initialize the USART mode according to the specified
 292:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   *         parameters in the USART_InitTypeDef and initialize the associated handle.
 293:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   * @param  husart Pointer to a USART_HandleTypeDef structure that contains
 294:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   *                the configuration information for the specified USART module.
 295:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   * @retval HAL status
 296:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   */
 297:./f103/HAL/Src/stm32f1xx_hal_usart.c **** HAL_StatusTypeDef HAL_USART_Init(USART_HandleTypeDef *husart)
 298:./f103/HAL/Src/stm32f1xx_hal_usart.c **** {
 299:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   /* Check the USART handle allocation */
 300:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   if (husart == NULL)
 301:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   {
 302:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     return HAL_ERROR;
 303:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   }
 304:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 305:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   /* Check the parameters */
 306:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   assert_param(IS_USART_INSTANCE(husart->Instance));
 307:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 308:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   if (husart->State == HAL_USART_STATE_RESET)
 309:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   {
 310:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     /* Allocate lock resource and initialize it */
 311:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     husart->Lock = HAL_UNLOCKED;
 312:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 313:./f103/HAL/Src/stm32f1xx_hal_usart.c **** #if (USE_HAL_USART_REGISTER_CALLBACKS == 1)
 314:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     USART_InitCallbacksToDefault(husart);
 315:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 316:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     if (husart->MspInitCallback == NULL)
 317:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     {
ARM GAS  C:\WINDOWS\ccnv4A6V.s 			page 7


 318:./f103/HAL/Src/stm32f1xx_hal_usart.c ****       husart->MspInitCallback = HAL_USART_MspInit;
 319:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     }
 320:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 321:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     /* Init the low level hardware */
 322:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     husart->MspInitCallback(husart);
 323:./f103/HAL/Src/stm32f1xx_hal_usart.c **** #else
 324:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     /* Init the low level hardware : GPIO, CLOCK */
 325:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     HAL_USART_MspInit(husart);
 326:./f103/HAL/Src/stm32f1xx_hal_usart.c **** #endif /* USE_HAL_USART_REGISTER_CALLBACKS */
 327:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   }
 328:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 329:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   husart->State = HAL_USART_STATE_BUSY;
 330:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 331:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   /* Set the USART Communication parameters */
 332:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   USART_SetConfig(husart);
 333:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 334:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   /* In USART mode, the following bits must be kept cleared:
 335:./f103/HAL/Src/stm32f1xx_hal_usart.c ****      - LINEN bit in the USART_CR2 register
 336:./f103/HAL/Src/stm32f1xx_hal_usart.c ****      - HDSEL, SCEN and IREN bits in the USART_CR3 register */
 337:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   CLEAR_BIT(husart->Instance->CR2, USART_CR2_LINEN);
 338:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   CLEAR_BIT(husart->Instance->CR3, (USART_CR3_SCEN | USART_CR3_HDSEL | USART_CR3_IREN));
 339:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 340:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   /* Enable the Peripheral */
 341:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   __HAL_USART_ENABLE(husart);
 342:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 343:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   /* Initialize the USART state */
 344:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   husart->ErrorCode = HAL_USART_ERROR_NONE;
 345:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   husart->State = HAL_USART_STATE_READY;
 346:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 347:./f103/HAL/Src/stm32f1xx_hal_usart.c ****   return HAL_OK;
 348:./f103/HAL/Src/stm32f1xx_hal_usart.c **** }
