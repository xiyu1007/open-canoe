 764:./f103/HAL/Src/stm32f1xx_hal_usart.c **** 
 765:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     /* In case of 9bits/No Parity transfer, pTxData needs to be handled as a uint16_t pointer */
 766:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     if ((husart->Init.WordLength == USART_WORDLENGTH_9B) && (husart->Init.Parity == USART_PARITY_NO
 767:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     {
 768:./f103/HAL/Src/stm32f1xx_hal_usart.c ****       ptxdata8bits  = NULL;
 769:./f103/HAL/Src/stm32f1xx_hal_usart.c ****       ptxdata16bits = (const uint16_t *) pTxData;
 770:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     }
 771:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     else
 772:./f103/HAL/Src/stm32f1xx_hal_usart.c ****     {
