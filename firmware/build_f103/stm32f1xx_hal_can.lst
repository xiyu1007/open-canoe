   1:./f103/HAL/Src/stm32f1xx_hal_can.c **** /**
   2:./f103/HAL/Src/stm32f1xx_hal_can.c ****   ******************************************************************************
   3:./f103/HAL/Src/stm32f1xx_hal_can.c ****   * @file    stm32f1xx_hal_can.c
   4:./f103/HAL/Src/stm32f1xx_hal_can.c ****   * @author  MCD Application Team
   5:./f103/HAL/Src/stm32f1xx_hal_can.c ****   * @brief   CAN HAL module driver.
   6:./f103/HAL/Src/stm32f1xx_hal_can.c ****   *          This file provides firmware functions to manage the following
   7:./f103/HAL/Src/stm32f1xx_hal_can.c ****   *          functionalities of the Controller Area Network (CAN) peripheral:
   8:./f103/HAL/Src/stm32f1xx_hal_can.c ****   *           + Initialization and de-initialization functions
   9:./f103/HAL/Src/stm32f1xx_hal_can.c ****   *           + Configuration functions
  10:./f103/HAL/Src/stm32f1xx_hal_can.c ****   *           + Control functions
  11:./f103/HAL/Src/stm32f1xx_hal_can.c ****   *           + Interrupts management
  12:./f103/HAL/Src/stm32f1xx_hal_can.c ****   *           + Callbacks functions
  13:./f103/HAL/Src/stm32f1xx_hal_can.c ****   *           + Peripheral State and Error functions
  14:./f103/HAL/Src/stm32f1xx_hal_can.c ****   *
  15:./f103/HAL/Src/stm32f1xx_hal_can.c ****   ******************************************************************************
  16:./f103/HAL/Src/stm32f1xx_hal_can.c ****   * @attention
