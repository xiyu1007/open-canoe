 102:src/main.c    **** 
 103:src/main.c    ****     /*---- Step 8: Main Loop ----*/
 104:src/main.c    ****     while (1)
 105:src/main.c    ****     {
 106:src/main.c    ****         uint8_t byte_buf[64];
 107:src/main.c    ****         uint16_t recv_len;
 108:src/main.c    ****         comm_status_t ret = comm_receive(byte_buf, sizeof(byte_buf), &recv_len, 0);
 109:src/main.c    ****         if (ret == COMM_OK && recv_len > 0) {
 110:src/main.c    ****             protocol_process_buffer(byte_buf, recv_len);
 111:src/main.c    ****         }
 112:src/main.c    ****     }
 113:src/main.c    **** }
