 189:./f103/system_stm32f1xx.c **** /**
 190:./f103/system_stm32f1xx.c ****   * @brief  Update SystemCoreClock variable according to Clock Register Values.
 191:./f103/system_stm32f1xx.c ****   *         The SystemCoreClock variable contains the core clock (HCLK), it can
 192:./f103/system_stm32f1xx.c ****   *         be used by the user application to setup the SysTick timer or configure
 193:./f103/system_stm32f1xx.c ****   *         other parameters.
 194:./f103/system_stm32f1xx.c ****   *           
 195:./f103/system_stm32f1xx.c ****   * @note   Each time the core clock (HCLK) changes, this function must be called
 196:./f103/system_stm32f1xx.c ****   *         to update SystemCoreClock variable value. Otherwise, any configuration
 197:./f103/system_stm32f1xx.c ****   *         based on this variable will be incorrect.         
 198:./f103/system_stm32f1xx.c ****   *     
 199:./f103/system_stm32f1xx.c ****   * @note   - The system frequency computed by this function is not the real 
 200:./f103/system_stm32f1xx.c ****   *           frequency in the chip. It is calculated based on the predefined 
 201:./f103/system_stm32f1xx.c ****   *           constant and the selected clock source:
 202:./f103/system_stm32f1xx.c ****   *             
 203:./f103/system_stm32f1xx.c ****   *           - If SYSCLK source is HSI, SystemCoreClock will contain the HSI_VALUE(*)
 204:./f103/system_stm32f1xx.c ****   *                                              
 205:./f103/system_stm32f1xx.c ****   *           - If SYSCLK source is HSE, SystemCoreClock will contain the HSE_VALUE(**)
 206:./f103/system_stm32f1xx.c ****   *                          
 207:./f103/system_stm32f1xx.c ****   *           - If SYSCLK source is PLL, SystemCoreClock will contain the HSE_VALUE(**) 
 208:./f103/system_stm32f1xx.c ****   *             or HSI_VALUE(*) multiplied by the PLL factors.
 209:./f103/system_stm32f1xx.c ****   *         
 210:./f103/system_stm32f1xx.c ****   *         (*) HSI_VALUE is a constant defined in stm32f1xx.h file (default value
 211:./f103/system_stm32f1xx.c ****   *             8 MHz) but the real value may vary depending on the variations
 212:./f103/system_stm32f1xx.c ****   *             in voltage and temperature.   
 213:./f103/system_stm32f1xx.c ****   *    
 214:./f103/system_stm32f1xx.c ****   *         (**) HSE_VALUE is a constant defined in stm32f1xx.h file (default value
 215:./f103/system_stm32f1xx.c ****   *              8 MHz or 25 MHz, depending on the product used), user has to ensure
 216:./f103/system_stm32f1xx.c ****   *              that HSE_VALUE is same as the real frequency of the crystal used.
 217:./f103/system_stm32f1xx.c ****   *              Otherwise, this function may have wrong result.
 218:./f103/system_stm32f1xx.c ****   *                
 219:./f103/system_stm32f1xx.c ****   *         - The result of this function could be not correct when using fractional
 220:./f103/system_stm32f1xx.c ****   *           value for HSE crystal.
 221:./f103/system_stm32f1xx.c ****   * @param  None
 222:./f103/system_stm32f1xx.c ****   * @retval None
 223:./f103/system_stm32f1xx.c ****   */
 224:./f103/system_stm32f1xx.c **** void SystemCoreClockUpdate (void)
 225:./f103/system_stm32f1xx.c **** {
