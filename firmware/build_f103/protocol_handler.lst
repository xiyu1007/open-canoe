  55:src/protocol_handler.c **** /**
ARM GAS  C:\WINDOWS\cciIg2oO.s 			page 5


  56:src/protocol_handler.c ****  * @brief Write a protocol frame into the output buffer.
  57:src/protocol_handler.c ****  * @param cmd       Command/response code
  58:src/protocol_handler.c ****  * @param data      Payload data (can be NULL if data_len == 0)
  59:src/protocol_handler.c ****  * @param data_len  Payload length in bytes
  60:src/protocol_handler.c ****  * @param out_buf   Output buffer (caller-allocated)
  61:src/protocol_handler.c ****  * @param out_len   Output: total frame length written
  62:src/protocol_handler.c ****  * @return 0 on success, -1 if data_len exceeds max
  63:src/protocol_handler.c ****  */
  64:src/protocol_handler.c **** static int proto_build_frame(uint8_t cmd, const uint8_t *data,
  65:src/protocol_handler.c ****                              uint16_t data_len, uint8_t *out_buf,
  66:src/protocol_handler.c ****                              uint16_t *out_len)
  67:src/protocol_handler.c **** {
  68:src/protocol_handler.c ****     if (data_len > PROTOCOL_FRAME_DATA_MAX) return -1;
  69:src/protocol_handler.c **** 
  70:src/protocol_handler.c ****     uint16_t total_len = PROTO_CALC_LENGTH(data_len);
  71:src/protocol_handler.c ****     uint16_t seq = g_seq_counter++;
  72:src/protocol_handler.c **** 
  73:src/protocol_handler.c ****     /* Header */
  74:src/protocol_handler.c ****     out_buf[0] = PROTOCOL_MAGIC_HEADER;
  75:src/protocol_handler.c ****     out_buf[1] = (uint8_t)(total_len & 0xFF);
  76:src/protocol_handler.c ****     out_buf[2] = (uint8_t)((total_len >> 8) & 0xFF);
  77:src/protocol_handler.c ****     out_buf[3] = cmd;
  78:src/protocol_handler.c ****     out_buf[4] = (uint8_t)(seq & 0xFF);
  79:src/protocol_handler.c ****     out_buf[5] = (uint8_t)((seq >> 8) & 0xFF);
  80:src/protocol_handler.c **** 
  81:src/protocol_handler.c ****     /* Data */
  82:src/protocol_handler.c ****     if (data_len > 0 && data != NULL) {
  83:src/protocol_handler.c ****         memcpy(&out_buf[PROTOCOL_FRAME_HEADER_SIZE], data, data_len);
  84:src/protocol_handler.c ****     }
  85:src/protocol_handler.c **** 
  86:src/protocol_handler.c ****     /* CRC16 over header + data */
  87:src/protocol_handler.c ****     uint16_t crc = crc16_compute(out_buf, PROTOCOL_FRAME_HEADER_SIZE + data_len);
  88:src/protocol_handler.c ****     uint16_t crc_offset = PROTOCOL_FRAME_HEADER_SIZE + data_len;
  89:src/protocol_handler.c ****     out_buf[crc_offset]     = (uint8_t)(crc & 0xFF);
  90:src/protocol_handler.c ****     out_buf[crc_offset + 1] = (uint8_t)((crc >> 8) & 0xFF);
  91:src/protocol_handler.c **** 
  92:src/protocol_handler.c ****     /* End magic */
  93:src/protocol_handler.c ****     out_buf[crc_offset + 2] = PROTOCOL_END_MAGIC;
  94:src/protocol_handler.c **** 
  95:src/protocol_handler.c ****     *out_len = total_len;
  96:src/protocol_handler.c ****     return 0;
  97:src/protocol_handler.c **** }
  98:src/protocol_handler.c **** 
  99:src/protocol_handler.c **** /**
 100:src/protocol_handler.c ****  * @brief Send a response frame (no data payload).
 101:src/protocol_handler.c ****  */
 102:src/protocol_handler.c **** static int proto_send_simple(uint8_t cmd)
 103:src/protocol_handler.c **** {
 104:src/protocol_handler.c ****     uint8_t buf[PROTOCOL_FRAME_TOTAL_MAX];
 105:src/protocol_handler.c ****     uint16_t len;
 106:src/protocol_handler.c ****     if (proto_build_frame(cmd, NULL, 0, buf, &len) != 0) return -1;
 107:src/protocol_handler.c ****     return (comm_send(buf, len, 100) == COMM_OK) ? 0 : -1;
 108:src/protocol_handler.c **** }
 109:src/protocol_handler.c **** 
 110:src/protocol_handler.c **** /**
 111:src/protocol_handler.c ****  * @brief Send a response with payload.
 112:src/protocol_handler.c ****  */
