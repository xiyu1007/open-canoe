 113:src/protocol_handler.c **** static int proto_send_data(uint8_t cmd, const uint8_t *data, uint16_t data_len)
 114:src/protocol_handler.c **** {
 115:src/protocol_handler.c ****     uint8_t buf[PROTOCOL_FRAME_TOTAL_MAX];
 116:src/protocol_handler.c ****     uint16_t len;
 117:src/protocol_handler.c ****     if (proto_build_frame(cmd, data, data_len, buf, &len) != 0) return -1;
 118:src/protocol_handler.c ****     return (comm_send(buf, len, 100) == COMM_OK) ? 0 : -1;
 119:src/protocol_handler.c **** }
