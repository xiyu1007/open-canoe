 173:src/protocol_handler.c ****     resp.comm_interface = (uint8_t)comm_get_current_interface();
 174:src/protocol_handler.c ****     resp.uptime_ms      = device_get_uptime_ms();
 175:src/protocol_handler.c **** 
 176:src/protocol_handler.c ****     /* Check CAN channels active */
 177:src/protocol_handler.c ****     uint8_t ch_active = 0;
 178:src/protocol_handler.c ****     for (uint8_t ch = 0; ch < can_get_channel_count(); ch++) {
