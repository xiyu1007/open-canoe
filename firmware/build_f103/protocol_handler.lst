 194:src/protocol_handler.c **** static void handle_get_adc_status(const uint8_t *data, uint16_t data_len)
 195:src/protocol_handler.c **** {
 196:src/protocol_handler.c ****     (void)data;
 197:src/protocol_handler.c ****     (void)data_len;
 198:src/protocol_handler.c **** 
 199:src/protocol_handler.c ****     uint8_t is_sampling = 0;
 200:src/protocol_handler.c ****     uint32_t sample_rate = 0;
 201:src/protocol_handler.c ****     uint8_t resolution = 0;
 202:src/protocol_handler.c ****     uint8_t available = adc_is_available();
 203:src/protocol_handler.c **** 
 204:src/protocol_handler.c ****     if (available) {
 205:src/protocol_handler.c ****         adc_get_status(&is_sampling, &sample_rate, &resolution);
 206:src/protocol_handler.c ****     }
 207:src/protocol_handler.c **** 
 208:src/protocol_handler.c ****     /* Simple ADC status response: [available][is_sampling][resolution][sample_rate(4)] */
 209:src/protocol_handler.c ****     uint8_t resp[7];
 210:src/protocol_handler.c ****     resp[0] = available;
 211:src/protocol_handler.c ****     resp[1] = is_sampling;
 212:src/protocol_handler.c ****     resp[2] = resolution;
 213:src/protocol_handler.c ****     resp[3] = (uint8_t)(sample_rate & 0xFF);
 214:src/protocol_handler.c ****     resp[4] = (uint8_t)((sample_rate >> 8) & 0xFF);
 215:src/protocol_handler.c ****     resp[5] = (uint8_t)((sample_rate >> 16) & 0xFF);
 216:src/protocol_handler.c ****     resp[6] = (uint8_t)((sample_rate >> 24) & 0xFF);
 217:src/protocol_handler.c **** 
 218:src/protocol_handler.c ****     proto_send_data(MSG_ADC_STATUS_RESP, resp, sizeof(resp));
 219:src/protocol_handler.c **** }
