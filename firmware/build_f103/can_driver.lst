 526:src/can_driver.c ****     if (rx_error_cnt)   *rx_error_cnt = (uint8_t)((esr >> 24) & 0xFF);
 527:src/can_driver.c **** 
 528:src/can_driver.c ****     return CAN_OK;
 529:src/can_driver.c **** }
