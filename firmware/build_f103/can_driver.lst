 517:src/can_driver.c ****         case 0x03: flags |= CAN_ERR_ACK; break;
 518:src/can_driver.c ****         case 0x04: /* Bit recessive error */ break;
 519:src/can_driver.c ****         case 0x05: /* Bit dominant error */ break;
 520:src/can_driver.c ****         case 0x06: flags |= CAN_ERR_CRC; break;
 521:src/can_driver.c ****         }
