 176:src/can_driver.c **** 
 177:src/can_driver.c **** can_status_t can_init(uint8_t channel, const can_config_t *config)
 178:src/can_driver.c **** {
 179:src/can_driver.c ****     if (channel >= CAN_INSTANCE_COUNT || !config) return CAN_ERR_PARAM;
 180:src/can_driver.c **** 
 181:src/can_driver.c ****     can_channel_ctx_t *ctx = can_get_ctx(channel);
 182:src/can_driver.c ****     CAN_HandleTypeDef  *h   = can_get_handle(channel);
 183:src/can_driver.c ****     if (!ctx || !h) return CAN_ERR_PARAM;
 184:src/can_driver.c **** 
 185:src/can_driver.c ****     /* De-init if already initialized */
 186:src/can_driver.c ****     if (ctx->initialized) {
 187:src/can_driver.c ****         can_deinit(channel);
 188:src/can_driver.c ****     }
 189:src/can_driver.c **** 
 190:src/can_driver.c ****     /* Compute timing */
 191:src/can_driver.c ****     uint32_t psc, bs1, bs2, sjw;
 192:src/can_driver.c ****     if (can_calc_timing(config->baudrate, &psc, &bs1, &bs2, &sjw) != CAN_OK) {
 193:src/can_driver.c ****         return CAN_ERR_PARAM;
 194:src/can_driver.c ****     }
 195:src/can_driver.c **** 
ARM GAS  C:\WINDOWS\ccErzQk2.s 			page 15


 196:src/can_driver.c ****     /* Initialize HAL CAN handle */
 197:src/can_driver.c ****     memset(h, 0, sizeof(*h));
 198:src/can_driver.c ****     if (channel == 0) {
 199:src/can_driver.c ****         h->Instance = CAN1;
 200:src/can_driver.c ****     }
 201:src/can_driver.c **** #if CAN_INSTANCE_COUNT > 1
 202:src/can_driver.c ****     else if (channel == 1) {
 203:src/can_driver.c ****         h->Instance = CAN2;
 204:src/can_driver.c ****     }
 205:src/can_driver.c **** #endif
 206:src/can_driver.c **** 
 207:src/can_driver.c ****     h->Init.Prescaler     = psc;
 208:src/can_driver.c ****     h->Init.Mode          = CAN_MODE_NORMAL;
 209:src/can_driver.c ****     h->Init.SyncJumpWidth = CAN_SJW_1TQ + (sjw - 1);
 210:src/can_driver.c ****     h->Init.TimeSeg1      = CAN_BS1_1TQ + (bs1 - 1);
 211:src/can_driver.c ****     h->Init.TimeSeg2      = CAN_BS2_1TQ + (bs2 - 1);
 212:src/can_driver.c ****     h->Init.TimeTriggeredMode = DISABLE;
 213:src/can_driver.c ****     h->Init.AutoBusOff         = ENABLE;
 214:src/can_driver.c ****     h->Init.AutoWakeUp         = DISABLE;
 215:src/can_driver.c ****     h->Init.AutoRetransmission = ENABLE;
 216:src/can_driver.c ****     h->Init.ReceiveFifoLocked  = DISABLE;
 217:src/can_driver.c ****     h->Init.TransmitFifoPriority = DISABLE;
 218:src/can_driver.c **** 
 219:src/can_driver.c ****     /* MSP init (pins, clock, NVIC) */
 220:src/can_driver.c ****     can_msp_init(channel);
 221:src/can_driver.c **** 
 222:src/can_driver.c ****     if (HAL_CAN_Init(h) != HAL_OK) {
 223:src/can_driver.c ****         return CAN_ERR_HW;
 224:src/can_driver.c ****     }
 225:src/can_driver.c **** 
 226:src/can_driver.c ****     /* Start in requested mode */
 227:src/can_driver.c ****     can_set_mode(channel, config->mode);
 228:src/can_driver.c **** 
 229:src/can_driver.c ****     /* Configure default filter (accept all) */
 230:src/can_driver.c ****     CAN_FilterTypeDef filter = {0};
 231:src/can_driver.c ****     filter.FilterBank = 0;
 232:src/can_driver.c ****     filter.FilterMode = CAN_FILTERMODE_IDMASK;
 233:src/can_driver.c ****     filter.FilterScale = CAN_FILTERSCALE_32BIT;
 234:src/can_driver.c ****     filter.FilterIdHigh   = 0;
 235:src/can_driver.c ****     filter.FilterIdLow    = 0;
 236:src/can_driver.c ****     filter.FilterMaskIdHigh = 0;
 237:src/can_driver.c ****     filter.FilterMaskIdLow  = 0;
 238:src/can_driver.c ****     filter.FilterFIFOAssignment = CAN_FILTER_FIFO0;
 239:src/can_driver.c ****     filter.FilterActivation = ENABLE;
 240:src/can_driver.c ****     filter.SlaveStartFilterBank = (channel == 0 && CAN_INSTANCE_COUNT > 1) ? 14 : 0;
 241:src/can_driver.c **** 
 242:src/can_driver.c ****     HAL_CAN_ConfigFilter(h, &filter);
 243:src/can_driver.c **** 
 244:src/can_driver.c ****     /* Activate notification for RX FIFO0 */
 245:src/can_driver.c ****     HAL_CAN_ActivateNotification(h, CAN_IT_RX_FIFO0_MSG_PENDING |
 246:src/can_driver.c ****                                      CAN_IT_ERROR |
 247:src/can_driver.c ****                                      CAN_IT_BUSOFF |
 248:src/can_driver.c ****                                      CAN_IT_LAST_ERROR_CODE);
 249:src/can_driver.c **** 
 250:src/can_driver.c ****     /* Save config */
 251:src/can_driver.c ****     memcpy(&ctx->config, config, sizeof(can_config_t));
 252:src/can_driver.c ****     memset(&ctx->stats, 0, sizeof(can_stats_t));
ARM GAS  C:\WINDOWS\ccErzQk2.s 			page 16


 253:src/can_driver.c ****     ctx->initialized = 1;
 254:src/can_driver.c ****     ctx->listening = 0;
 255:src/can_driver.c **** 
 256:src/can_driver.c ****     return CAN_OK;
 257:src/can_driver.c **** }
 258:src/can_driver.c **** 
 259:src/can_driver.c **** can_status_t can_deinit(uint8_t channel)
 260:src/can_driver.c **** {
 261:src/can_driver.c ****     if (channel >= CAN_INSTANCE_COUNT) return CAN_ERR_PARAM;
 262:src/can_driver.c ****     can_channel_ctx_t *ctx = can_get_ctx(channel);
 263:src/can_driver.c ****     CAN_HandleTypeDef  *h   = can_get_handle(channel);
 264:src/can_driver.c ****     if (!ctx || !h) return CAN_ERR_PARAM;
 265:src/can_driver.c **** 
 266:src/can_driver.c ****     can_stop_listen(channel);
 267:src/can_driver.c ****     HAL_CAN_DeInit(h);
 268:src/can_driver.c ****     ctx->initialized = 0;
 269:src/can_driver.c **** 
 270:src/can_driver.c ****     return CAN_OK;
