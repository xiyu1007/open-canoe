 562:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /*   disabled, discards automatically nb of conversions. Anyway, nb of    */
 563:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /*   conversions is forced to 0x00 for alignment over all STM32 devices.  */
 564:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* - if scan mode is enabled, regular channels sequence length is set to  */
 565:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /*   parameter "NbrOfConversion"                                          */
