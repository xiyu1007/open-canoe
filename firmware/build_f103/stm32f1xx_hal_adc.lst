2096:./f103/HAL/Src/stm32f1xx_hal_adc.c **** /**
2097:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @brief  Configures the analog watchdog.
2098:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @note   Analog watchdog thresholds can be modified while ADC conversion
2099:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         is on going.
2100:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         In this case, some constraints must be taken into account:
2101:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         the programmed threshold values are effective from the next
2102:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         ADC EOC (end of unitary conversion).
2103:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         Considering that registers write delay may happen due to
2104:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         bus activity, this might cause an uncertainty on the
2105:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         effective timing of the new programmed threshold values.
2106:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @param  hadc: ADC handle
2107:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @param  AnalogWDGConfig: Structure of ADC analog watchdog configuration
2108:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @retval HAL status
2109:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   */
2110:./f103/HAL/Src/stm32f1xx_hal_adc.c **** HAL_StatusTypeDef HAL_ADC_AnalogWDGConfig(ADC_HandleTypeDef* hadc, ADC_AnalogWDGConfTypeDef* Analog
2111:./f103/HAL/Src/stm32f1xx_hal_adc.c **** {
2112:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Check the parameters */
2113:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   assert_param(IS_ADC_ALL_INSTANCE(hadc->Instance));
2114:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   assert_param(IS_ADC_ANALOG_WATCHDOG_MODE(AnalogWDGConfig->WatchdogMode));
2115:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   assert_param(IS_FUNCTIONAL_STATE(AnalogWDGConfig->ITMode));
2116:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   assert_param(IS_ADC_RANGE(AnalogWDGConfig->HighThreshold));
2117:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   assert_param(IS_ADC_RANGE(AnalogWDGConfig->LowThreshold));
2118:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
2119:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   if((AnalogWDGConfig->WatchdogMode == ADC_ANALOGWATCHDOG_SINGLE_REG)     ||
2120:./f103/HAL/Src/stm32f1xx_hal_adc.c ****      (AnalogWDGConfig->WatchdogMode == ADC_ANALOGWATCHDOG_SINGLE_INJEC)   ||
2121:./f103/HAL/Src/stm32f1xx_hal_adc.c ****      (AnalogWDGConfig->WatchdogMode == ADC_ANALOGWATCHDOG_SINGLE_REGINJEC)  )
2122:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   {
2123:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     assert_param(IS_ADC_CHANNEL(AnalogWDGConfig->Channel));
2124:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   }
2125:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
2126:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Process locked */
2127:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   __HAL_LOCK(hadc);
2128:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
2129:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Analog watchdog configuration */
2130:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
ARM GAS  C:\WINDOWS\ccjOB5ii.s 			page 49


2131:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Configure ADC Analog watchdog interrupt */
2132:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   if(AnalogWDGConfig->ITMode == ENABLE)
2133:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   {
2134:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* Enable the ADC Analog watchdog interrupt */
2135:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     __HAL_ADC_ENABLE_IT(hadc, ADC_IT_AWD);
2136:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   }
2137:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   else
2138:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   {
2139:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* Disable the ADC Analog watchdog interrupt */
2140:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     __HAL_ADC_DISABLE_IT(hadc, ADC_IT_AWD);
2141:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   }
2142:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
2143:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Configuration of analog watchdog:                                        */
2144:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /*  - Set the analog watchdog enable mode: regular and/or injected groups,  */
2145:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /*    one or all channels.                                                  */
2146:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /*  - Set the Analog watchdog channel (is not used if watchdog              */
2147:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /*    mode "all channels": ADC_CFGR_AWD1SGL=0).                             */
2148:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   MODIFY_REG(hadc->Instance->CR1            ,
2149:./f103/HAL/Src/stm32f1xx_hal_adc.c ****              ADC_CR1_AWDSGL |
2150:./f103/HAL/Src/stm32f1xx_hal_adc.c ****              ADC_CR1_JAWDEN |
2151:./f103/HAL/Src/stm32f1xx_hal_adc.c ****              ADC_CR1_AWDEN  |
2152:./f103/HAL/Src/stm32f1xx_hal_adc.c ****              ADC_CR1_AWDCH                  ,
2153:./f103/HAL/Src/stm32f1xx_hal_adc.c ****              AnalogWDGConfig->WatchdogMode |
2154:./f103/HAL/Src/stm32f1xx_hal_adc.c ****              AnalogWDGConfig->Channel        );
2155:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
2156:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Set the high threshold */
2157:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   WRITE_REG(hadc->Instance->HTR, AnalogWDGConfig->HighThreshold);
2158:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
2159:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Set the low threshold */
2160:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   WRITE_REG(hadc->Instance->LTR, AnalogWDGConfig->LowThreshold);
2161:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
2162:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Process unlocked */
2163:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   __HAL_UNLOCK(hadc);
2164:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
2165:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Return function status */
2166:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   return HAL_OK;
2167:./f103/HAL/Src/stm32f1xx_hal_adc.c **** }
