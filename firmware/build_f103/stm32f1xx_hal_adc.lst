 350:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Unit: us                                                                 */
 351:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   #define ADC_TEMPSENSOR_DELAY_US         10U
