 388:./f103/HAL/Src/stm32f1xx_hal_adc.c **** /**
 389:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @brief  Initializes the ADC peripheral and regular group according to  
 390:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         parameters specified in structure "ADC_InitTypeDef".
 391:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @note   As prerequisite, ADC clock must be configured at RCC top level
 392:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         (clock source APB2).
 393:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         See commented example code below that can be copied and uncommented 
 394:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         into HAL_ADC_MspInit().
 395:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @note   Possibility to update parameters on the fly:
 396:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         This function initializes the ADC MSP (HAL_ADC_MspInit()) only when
 397:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         coming from ADC state reset. Following calls to this function can
 398:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         be used to reconfigure some parameters of ADC_InitTypeDef  
 399:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         structure on the fly, without modifying MSP configuration. If ADC  
 400:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         MSP has to be modified again, HAL_ADC_DeInit() must be called
 401:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         before HAL_ADC_Init().
 402:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         The setting of these parameters is conditioned to ADC state.
 403:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         For parameters constraints, see comments of structure 
 404:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         "ADC_InitTypeDef".
 405:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @note   This function configures the ADC within 2 scopes: scope of entire 
 406:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         ADC and scope of regular group. For parameters details, see comments 
 407:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         of structure "ADC_InitTypeDef".
 408:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @param  hadc: ADC handle
 409:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @retval HAL status
 410:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   */
 411:./f103/HAL/Src/stm32f1xx_hal_adc.c **** HAL_StatusTypeDef HAL_ADC_Init(ADC_HandleTypeDef* hadc)
 412:./f103/HAL/Src/stm32f1xx_hal_adc.c **** {
 413:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   HAL_StatusTypeDef tmp_hal_status = HAL_OK;
 414:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   uint32_t tmp_cr1 = 0U;
 415:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   uint32_t tmp_cr2 = 0U;
 416:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   uint32_t tmp_sqr1 = 0U;
 417:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
 418:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Check ADC handle */
 419:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   if(hadc == NULL)
 420:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   {
 421:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     return HAL_ERROR;
 422:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   }
 423:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
 424:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Check the parameters */
 425:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   assert_param(IS_ADC_ALL_INSTANCE(hadc->Instance));
 426:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   assert_param(IS_ADC_DATA_ALIGN(hadc->Init.DataAlign));
 427:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   assert_param(IS_ADC_SCAN_MODE(hadc->Init.ScanConvMode));
 428:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   assert_param(IS_FUNCTIONAL_STATE(hadc->Init.ContinuousConvMode));
 429:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   assert_param(IS_ADC_EXTTRIG(hadc->Init.ExternalTrigConv));
 430:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
ARM GAS  C:\WINDOWS\ccjOB5ii.s 			page 9


 431:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   if(hadc->Init.ScanConvMode != ADC_SCAN_DISABLE)
 432:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   {
 433:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     assert_param(IS_ADC_REGULAR_NB_CONV(hadc->Init.NbrOfConversion));
 434:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     assert_param(IS_FUNCTIONAL_STATE(hadc->Init.DiscontinuousConvMode));
 435:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     if(hadc->Init.DiscontinuousConvMode != DISABLE)
 436:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     {
 437:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       assert_param(IS_ADC_REGULAR_DISCONT_NUMBER(hadc->Init.NbrOfDiscConversion));
 438:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     }
