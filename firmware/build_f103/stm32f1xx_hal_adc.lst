2270:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
2271:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           /* Process unlocked */
2272:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           __HAL_UNLOCK(hadc);
2273:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
2274:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           return HAL_ERROR;
2275:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         }
2276:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       }
2277:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     }
2278:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   }
2279:./f103/HAL/Src/stm32f1xx_hal_adc.c ****    
2280:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Return HAL status */
2281:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   return HAL_OK;
2282:./f103/HAL/Src/stm32f1xx_hal_adc.c **** }
