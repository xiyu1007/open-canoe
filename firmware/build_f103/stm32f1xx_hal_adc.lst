 334:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Timeout values for ADC enable and disable settling time.                 */
 335:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Values defined to be higher than worst cases: low clocks freq,           */
 336:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* maximum prescaler.                                                       */
 337:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Ex of profile low frequency : Clock source at 0.1 MHz, ADC clock         */
 338:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* prescaler 4, sampling time 12.5 ADC clock cycles, resolution 12 bits.    */
 339:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Unit: ms                                                                 */
 340:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   #define ADC_ENABLE_TIMEOUT              2U
 341:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   #define ADC_DISABLE_TIMEOUT             2U
 342:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
 343:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Delay for ADC stabilization time.                                        */
 344:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Maximum delay is 1us (refer to device datasheet, parameter tSTAB).       */
 345:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Unit: us                                                                 */
