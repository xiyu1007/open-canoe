1030:./f103/HAL/Src/stm32f1xx_hal_adc.c **** /**
1031:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @brief  Enables ADC, starts conversion of regular group.
1032:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         Interruptions enabled in this function: None.
1033:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @param  hadc: ADC handle
1034:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @retval HAL status
1035:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   */
1036:./f103/HAL/Src/stm32f1xx_hal_adc.c **** HAL_StatusTypeDef HAL_ADC_Start(ADC_HandleTypeDef* hadc)
1037:./f103/HAL/Src/stm32f1xx_hal_adc.c **** {
1038:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   HAL_StatusTypeDef tmp_hal_status = HAL_OK;
1039:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
1040:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Check the parameters */
1041:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   assert_param(IS_ADC_ALL_INSTANCE(hadc->Instance));
1042:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
1043:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Process locked */
1044:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   __HAL_LOCK(hadc);
1045:./f103/HAL/Src/stm32f1xx_hal_adc.c ****    
1046:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Enable the ADC peripheral */
1047:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   tmp_hal_status = ADC_Enable(hadc);
1048:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
1049:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Start conversion if ADC is effectively enabled */
1050:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   if (tmp_hal_status == HAL_OK)
1051:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   {
1052:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* Set ADC state                                                          */
1053:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* - Clear state bitfield related to regular group conversion results     */
1054:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* - Set state bitfield related to regular operation                      */
1055:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     ADC_STATE_CLR_SET(hadc->State,
1056:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                       HAL_ADC_STATE_READY | HAL_ADC_STATE_REG_EOC,
1057:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                       HAL_ADC_STATE_REG_BUSY);
1058:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     
1059:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* Set group injected state (from auto-injection) and multimode state     */
1060:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* for all cases of multimode: independent mode, multimode ADC master     */
1061:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* or multimode ADC slave (for devices with several ADCs):                */
1062:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     if (ADC_NONMULTIMODE_OR_MULTIMODEMASTER(hadc))
1063:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     {
1064:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       /* Set ADC state (ADC independent or master) */
1065:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       CLEAR_BIT(hadc->State, HAL_ADC_STATE_MULTIMODE_SLAVE);
1066:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       
1067:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       /* If conversions on group regular are also triggering group injected,  */
1068:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       /* update ADC state.                                                    */
1069:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       if (READ_BIT(hadc->Instance->CR1, ADC_CR1_JAUTO) != RESET)
1070:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       {
