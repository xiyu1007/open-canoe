1140:./f103/HAL/Src/stm32f1xx_hal_adc.c **** /**
1141:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @brief  Stop ADC conversion of regular group (and injected channels in 
1142:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         case of auto_injection mode), disable ADC peripheral.
1143:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @note:  ADC peripheral disable is forcing stop of potential 
1144:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         conversion on injected group. If injected group is under use, it
1145:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         should be preliminarily stopped using HAL_ADCEx_InjectedStop function.
1146:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @param  hadc: ADC handle
1147:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @retval HAL status.
1148:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   */
1149:./f103/HAL/Src/stm32f1xx_hal_adc.c **** HAL_StatusTypeDef HAL_ADC_Stop(ADC_HandleTypeDef* hadc)
1150:./f103/HAL/Src/stm32f1xx_hal_adc.c **** {
1151:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   HAL_StatusTypeDef tmp_hal_status = HAL_OK;
1152:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
1153:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Check the parameters */
1154:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   assert_param(IS_ADC_ALL_INSTANCE(hadc->Instance));
1155:./f103/HAL/Src/stm32f1xx_hal_adc.c ****      
1156:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Process locked */
1157:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   __HAL_LOCK(hadc);
1158:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
1159:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Stop potential conversion on going, on regular and injected groups */
1160:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Disable ADC peripheral */
1161:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   tmp_hal_status = ADC_ConversionStop_Disable(hadc);
1162:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
1163:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Check if ADC is effectively disabled */
1164:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   if (tmp_hal_status == HAL_OK)
1165:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   {
1166:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* Set ADC state */
1167:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     ADC_STATE_CLR_SET(hadc->State,
1168:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                       HAL_ADC_STATE_REG_BUSY | HAL_ADC_STATE_INJ_BUSY,
1169:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                       HAL_ADC_STATE_READY);
1170:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   }
1171:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
1172:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Process unlocked */
1173:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   __HAL_UNLOCK(hadc);
1174:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
1175:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Return function status */
1176:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   return tmp_hal_status;
1177:./f103/HAL/Src/stm32f1xx_hal_adc.c **** }
