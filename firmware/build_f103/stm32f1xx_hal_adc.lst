2010:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
2011:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Process locked */
2012:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   __HAL_LOCK(hadc);
2013:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
2014:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
2015:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Regular sequence configuration */
2016:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* For Rank 1 to 6 */
ARM GAS  C:\WINDOWS\ccjOB5ii.s 			page 47


2017:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   if (sConfig->Rank < 7U)
2018:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   {
2019:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     MODIFY_REG(hadc->Instance->SQR3                        ,
2020:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                ADC_SQR3_RK(ADC_SQR3_SQ1, sConfig->Rank)    ,
2021:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                ADC_SQR3_RK(sConfig->Channel, sConfig->Rank) );
2022:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   }
2023:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* For Rank 7 to 12 */
2024:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   else if (sConfig->Rank < 13U)
2025:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   {
2026:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     MODIFY_REG(hadc->Instance->SQR2                        ,
2027:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                ADC_SQR2_RK(ADC_SQR2_SQ7, sConfig->Rank)    ,
2028:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                ADC_SQR2_RK(sConfig->Channel, sConfig->Rank) );
2029:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   }
2030:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* For Rank 13 to 16 */
2031:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   else
2032:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   {
2033:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     MODIFY_REG(hadc->Instance->SQR1                        ,
2034:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                ADC_SQR1_RK(ADC_SQR1_SQ13, sConfig->Rank)   ,
2035:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                ADC_SQR1_RK(sConfig->Channel, sConfig->Rank) );
2036:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   }
2037:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
2038:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
2039:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Channel sampling time configuration */
2040:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* For channels 10 to 17 */
2041:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   if (sConfig->Channel >= ADC_CHANNEL_10)
2042:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   {
2043:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     MODIFY_REG(hadc->Instance->SMPR1                             ,
2044:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                ADC_SMPR1(ADC_SMPR1_SMP10, sConfig->Channel)      ,
2045:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                ADC_SMPR1(sConfig->SamplingTime, sConfig->Channel) );
2046:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   }
2047:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   else /* For channels 0 to 9 */
2048:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   {
2049:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     MODIFY_REG(hadc->Instance->SMPR2                             ,
2050:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                ADC_SMPR2(ADC_SMPR2_SMP0, sConfig->Channel)       ,
2051:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                ADC_SMPR2(sConfig->SamplingTime, sConfig->Channel) );
2052:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   }
2053:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
2054:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* If ADC1 Channel_16 or Channel_17 is selected, enable Temperature sensor  */
2055:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* and VREFINT measurement path.                                            */
2056:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   if ((sConfig->Channel == ADC_CHANNEL_TEMPSENSOR) ||
2057:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       (sConfig->Channel == ADC_CHANNEL_VREFINT)      )
2058:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   {
2059:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* For STM32F1 devices with several ADC: Only ADC1 can access internal    */
2060:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* measurement channels (VrefInt/TempSensor). If these channels are       */
2061:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* intended to be set on other ADC instances, an error is reported.       */
2062:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     if (hadc->Instance == ADC1)
2063:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     {
2064:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       if (READ_BIT(hadc->Instance->CR2, ADC_CR2_TSVREFE) == RESET)
2065:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       {
2066:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         SET_BIT(hadc->Instance->CR2, ADC_CR2_TSVREFE);
2067:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         
2068:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         if (sConfig->Channel == ADC_CHANNEL_TEMPSENSOR)
2069:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         {
2070:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           /* Delay for temperature sensor stabilization time */
2071:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           /* Compute number of CPU cycles to wait for */
2072:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           wait_loop_index = (ADC_TEMPSENSOR_DELAY_US * (SystemCoreClock / 1000000U));
2073:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           while(wait_loop_index != 0U)
