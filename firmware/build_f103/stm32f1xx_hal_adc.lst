  67:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                      ##### How to use this driver #####
  68:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   ==============================================================================
  69:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     [..]
  70:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
  71:./f103/HAL/Src/stm32f1xx_hal_adc.c ****      *** Configuration of top level parameters related to ADC ***
  72:./f103/HAL/Src/stm32f1xx_hal_adc.c ****      ============================================================
  73:./f103/HAL/Src/stm32f1xx_hal_adc.c ****      [..]
  74:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
  75:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     (#) Enable the ADC interface
  76:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       (++) As prerequisite, ADC clock must be configured at RCC top level.
  77:./f103/HAL/Src/stm32f1xx_hal_adc.c ****            Caution: On STM32F1, ADC clock frequency max is 14MHz (refer
  78:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                     to device datasheet).
  79:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                     Therefore, ADC clock prescaler must be configured in 
  80:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                     function of ADC clock source frequency to remain below
  81:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                     this maximum frequency.
  82:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         (++) One clock setting is mandatory:
  83:./f103/HAL/Src/stm32f1xx_hal_adc.c ****              ADC clock (core clock, also possibly conversion clock).
  84:./f103/HAL/Src/stm32f1xx_hal_adc.c ****              (+++) Example:
  85:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                    Into HAL_ADC_MspInit() (recommended code location) or with
  86:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                    other device clock parameters configuration:
  87:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                (+++) RCC_PeriphCLKInitTypeDef  PeriphClkInit;
  88:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                (+++) __ADC1_CLK_ENABLE();
ARM GAS  C:\WINDOWS\ccjOB5ii.s 			page 3


  89:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                (+++) PeriphClkInit.PeriphClockSelection = RCC_PERIPHCLK_ADC;
  90:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                (+++) PeriphClkInit.AdcClockSelection = RCC_ADCPCLK2_DIV2;
  91:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                (+++) HAL_RCCEx_PeriphCLKConfig(&PeriphClkInit);
  92:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
  93:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     (#) ADC pins configuration
  94:./f103/HAL/Src/stm32f1xx_hal_adc.c ****          (++) Enable the clock for the ADC GPIOs
  95:./f103/HAL/Src/stm32f1xx_hal_adc.c ****               using macro __HAL_RCC_GPIOx_CLK_ENABLE()
  96:./f103/HAL/Src/stm32f1xx_hal_adc.c ****          (++) Configure these ADC pins in analog mode
  97:./f103/HAL/Src/stm32f1xx_hal_adc.c ****               using function HAL_GPIO_Init()
  98:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
  99:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     (#) Optionally, in case of usage of ADC with interruptions:
 100:./f103/HAL/Src/stm32f1xx_hal_adc.c ****          (++) Configure the NVIC for ADC
 101:./f103/HAL/Src/stm32f1xx_hal_adc.c ****               using function HAL_NVIC_EnableIRQ(ADCx_IRQn)
 102:./f103/HAL/Src/stm32f1xx_hal_adc.c ****          (++) Insert the ADC interruption handler function HAL_ADC_IRQHandler() 
 103:./f103/HAL/Src/stm32f1xx_hal_adc.c ****               into the function of corresponding ADC interruption vector 
 104:./f103/HAL/Src/stm32f1xx_hal_adc.c ****               ADCx_IRQHandler().
 105:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
 106:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     (#) Optionally, in case of usage of DMA:
 107:./f103/HAL/Src/stm32f1xx_hal_adc.c ****          (++) Configure the DMA (DMA channel, mode normal or circular, ...)
 108:./f103/HAL/Src/stm32f1xx_hal_adc.c ****               using function HAL_DMA_Init().
 109:./f103/HAL/Src/stm32f1xx_hal_adc.c ****          (++) Configure the NVIC for DMA
 110:./f103/HAL/Src/stm32f1xx_hal_adc.c ****               using function HAL_NVIC_EnableIRQ(DMAx_Channelx_IRQn)
 111:./f103/HAL/Src/stm32f1xx_hal_adc.c ****          (++) Insert the ADC interruption handler function HAL_ADC_IRQHandler() 
 112:./f103/HAL/Src/stm32f1xx_hal_adc.c ****               into the function of corresponding DMA interruption vector 
 113:./f103/HAL/Src/stm32f1xx_hal_adc.c ****               DMAx_Channelx_IRQHandler().
 114:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
 115:./f103/HAL/Src/stm32f1xx_hal_adc.c ****      *** Configuration of ADC, groups regular/injected, channels parameters ***
 116:./f103/HAL/Src/stm32f1xx_hal_adc.c ****      ==========================================================================
 117:./f103/HAL/Src/stm32f1xx_hal_adc.c ****      [..]
 118:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
 119:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     (#) Configure the ADC parameters (resolution, data alignment, ...)
 120:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         and regular group parameters (conversion trigger, sequencer, ...)
 121:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         using function HAL_ADC_Init().
 122:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
 123:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     (#) Configure the channels for regular group parameters (channel number, 
 124:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         channel rank into sequencer, ..., into regular group)
 125:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         using function HAL_ADC_ConfigChannel().
 126:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
 127:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     (#) Optionally, configure the injected group parameters (conversion trigger, 
 128:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         sequencer, ..., of injected group)
 129:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         and the channels for injected group parameters (channel number, 
 130:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         channel rank into sequencer, ..., into injected group)
 131:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         using function HAL_ADCEx_InjectedConfigChannel().
 132:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
 133:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     (#) Optionally, configure the analog watchdog parameters (channels
 134:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         monitored, thresholds, ...)
 135:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         using function HAL_ADC_AnalogWDGConfig().
 136:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
 137:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     (#) Optionally, for devices with several ADC instances: configure the 
 138:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         multimode parameters
 139:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         using function HAL_ADCEx_MultiModeConfigChannel().
 140:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
 141:./f103/HAL/Src/stm32f1xx_hal_adc.c ****      *** Execution of ADC conversions ***
 142:./f103/HAL/Src/stm32f1xx_hal_adc.c ****      ====================================
 143:./f103/HAL/Src/stm32f1xx_hal_adc.c ****      [..]
 144:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
 145:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     (#) Optionally, perform an automatic ADC calibration to improve the
ARM GAS  C:\WINDOWS\ccjOB5ii.s 			page 4


 146:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         conversion accuracy
 147:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         using function HAL_ADCEx_Calibration_Start().
 148:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
 149:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     (#) ADC driver can be used among three modes: polling, interruption,
 150:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         transfer by DMA.
 151:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
 152:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         (++) ADC conversion by polling:
 153:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Activate the ADC peripheral and start conversions
 154:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 using function HAL_ADC_Start()
 155:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Wait for ADC conversion completion 
 156:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 using function HAL_ADC_PollForConversion()
 157:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 (or for injected group: HAL_ADCEx_InjectedPollForConversion() )
 158:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Retrieve conversion results 
 159:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 using function HAL_ADC_GetValue()
 160:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 (or for injected group: HAL_ADCEx_InjectedGetValue() )
 161:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Stop conversion and disable the ADC peripheral 
 162:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 using function HAL_ADC_Stop()
 163:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
 164:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         (++) ADC conversion by interruption: 
 165:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Activate the ADC peripheral and start conversions
 166:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 using function HAL_ADC_Start_IT()
 167:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Wait for ADC conversion completion by call of function
 168:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 HAL_ADC_ConvCpltCallback()
 169:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 (this function must be implemented in user program)
 170:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 (or for injected group: HAL_ADCEx_InjectedConvCpltCallback() )
 171:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Retrieve conversion results 
 172:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 using function HAL_ADC_GetValue()
 173:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 (or for injected group: HAL_ADCEx_InjectedGetValue() )
 174:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Stop conversion and disable the ADC peripheral 
 175:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 using function HAL_ADC_Stop_IT()
 176:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
 177:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         (++) ADC conversion with transfer by DMA:
 178:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Activate the ADC peripheral and start conversions
 179:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 using function HAL_ADC_Start_DMA()
 180:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Wait for ADC conversion completion by call of function
 181:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 HAL_ADC_ConvCpltCallback() or HAL_ADC_ConvHalfCpltCallback()
 182:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 (these functions must be implemented in user program)
 183:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Conversion results are automatically transferred by DMA into
 184:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 destination variable address.
 185:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Stop conversion and disable the ADC peripheral 
 186:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 using function HAL_ADC_Stop_DMA()
 187:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
 188:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         (++) For devices with several ADCs: ADC multimode conversion 
 189:./f103/HAL/Src/stm32f1xx_hal_adc.c ****              with transfer by DMA:
 190:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Activate the ADC peripheral (slave) and start conversions
 191:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 using function HAL_ADC_Start()
 192:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Activate the ADC peripheral (master) and start conversions
 193:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 using function HAL_ADCEx_MultiModeStart_DMA()
 194:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Wait for ADC conversion completion by call of function
 195:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 HAL_ADC_ConvCpltCallback() or HAL_ADC_ConvHalfCpltCallback()
 196:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 (these functions must be implemented in user program)
 197:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Conversion results are automatically transferred by DMA into
 198:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 destination variable address.
 199:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Stop conversion and disable the ADC peripheral (master)
 200:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 using function HAL_ADCEx_MultiModeStop_DMA()
 201:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           (+++) Stop conversion and disable the ADC peripheral (slave)
 202:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                 using function HAL_ADC_Stop_IT()
ARM GAS  C:\WINDOWS\ccjOB5ii.s 			page 5


