2236:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
2237:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* ADC enable and wait for ADC ready (in case of ADC is disabled or         */
2238:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* enabling phase not yet completed: flag ADC ready not yet set).           */
2239:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Timeout implemented to not be stuck if ADC cannot be enabled (possible   */
2240:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* causes: ADC clock not running, ...).                                     */
2241:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   if (ADC_IS_ENABLE(hadc) == RESET)
2242:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   {
2243:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* Enable the Peripheral */
2244:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     __HAL_ADC_ENABLE(hadc);
ARM GAS  C:\WINDOWS\ccjOB5ii.s 			page 51


2245:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     
2246:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* Delay for ADC stabilization time */
2247:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* Compute number of CPU cycles to wait for */
2248:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     wait_loop_index = (ADC_STAB_DELAY_US * (SystemCoreClock / 1000000U));
2249:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     while(wait_loop_index != 0U)
2250:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     {
2251:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       wait_loop_index--;
2252:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     }
2253:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     
2254:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* Get tick count */
2255:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     tickstart = HAL_GetTick();
2256:./f103/HAL/Src/stm32f1xx_hal_adc.c **** 
2257:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* Wait for ADC effectively enabled */
2258:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     while(ADC_IS_ENABLE(hadc) == RESET)
2259:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     {
