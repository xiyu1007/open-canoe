1680:./f103/HAL/Src/stm32f1xx_hal_adc.c **** /**
1681:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @brief  Stop ADC conversion of regular group (and injected group in 
1682:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         case of auto_injection mode), disable ADC DMA transfer, disable 
1683:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         ADC peripheral.
1684:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @note:  ADC peripheral disable is forcing stop of potential 
1685:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         conversion on injected group. If injected group is under use, it
1686:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         should be preliminarily stopped using HAL_ADCEx_InjectedStop function.
1687:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @note   For devices with several ADCs: This function is for single-ADC mode 
1688:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         only. For multimode, use the dedicated MultimodeStop function.
1689:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @note   On STM32F1 devices, only ADC1 and ADC3 (ADC availability depending
1690:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         on devices) have DMA capability.
1691:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @param  hadc: ADC handle
1692:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @retval HAL status.
1693:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   */
1694:./f103/HAL/Src/stm32f1xx_hal_adc.c **** HAL_StatusTypeDef HAL_ADC_Stop_DMA(ADC_HandleTypeDef* hadc)
1695:./f103/HAL/Src/stm32f1xx_hal_adc.c **** {
1696:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   HAL_StatusTypeDef tmp_hal_status = HAL_OK;
1697:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
1698:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Check the parameters */
1699:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   assert_param(IS_ADC_DMA_CAPABILITY_INSTANCE(hadc->Instance));
1700:./f103/HAL/Src/stm32f1xx_hal_adc.c ****      
1701:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Process locked */
1702:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   __HAL_LOCK(hadc);
1703:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
1704:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Stop potential conversion on going, on regular and injected groups */
1705:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Disable ADC peripheral */
1706:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   tmp_hal_status = ADC_ConversionStop_Disable(hadc);
1707:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
1708:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Check if ADC is effectively disabled */
1709:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   if (tmp_hal_status == HAL_OK)
1710:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   {
1711:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* Disable ADC DMA mode */
1712:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     CLEAR_BIT(hadc->Instance->CR2, ADC_CR2_DMA);
1713:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     
1714:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* Disable the DMA channel (in case of DMA in circular mode or stop while */
1715:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     /* DMA transfer is on going)                                              */
1716:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     if (hadc->DMA_Handle->State == HAL_DMA_STATE_BUSY)
1717:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     {
1718:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       tmp_hal_status = HAL_DMA_Abort(hadc->DMA_Handle);
ARM GAS  C:\WINDOWS\ccjOB5ii.s 			page 41


1719:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       
1720:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       /* Check if DMA channel effectively disabled */
1721:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       if (tmp_hal_status == HAL_OK)
1722:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       {
1723:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         /* Set ADC state */
1724:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         ADC_STATE_CLR_SET(hadc->State,
1725:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                           HAL_ADC_STATE_REG_BUSY | HAL_ADC_STATE_INJ_BUSY,
1726:./f103/HAL/Src/stm32f1xx_hal_adc.c ****                           HAL_ADC_STATE_READY);
1727:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       }
1728:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       else
1729:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       {
1730:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         /* Update ADC state machine to error */
