2074:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           {
2075:./f103/HAL/Src/stm32f1xx_hal_adc.c ****             wait_loop_index--;
2076:./f103/HAL/Src/stm32f1xx_hal_adc.c ****           }
2077:./f103/HAL/Src/stm32f1xx_hal_adc.c ****         }
2078:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       }
2079:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     }
2080:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     else
2081:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     {
2082:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       /* Update ADC state machine to error */
