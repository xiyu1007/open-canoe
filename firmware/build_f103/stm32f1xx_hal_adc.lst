1981:./f103/HAL/Src/stm32f1xx_hal_adc.c **** /**
1982:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @brief  Configures the the selected channel to be linked to the regular
1983:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         group.
1984:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @note   In case of usage of internal measurement channels:
1985:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         Vbat/VrefInt/TempSensor.
1986:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         These internal paths can be be disabled using function 
1987:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         HAL_ADC_DeInit().
1988:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @note   Possibility to update parameters on the fly:
1989:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         This function initializes channel into regular group, following  
1990:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         calls to this function can be used to reconfigure some parameters 
1991:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         of structure "ADC_ChannelConfTypeDef" on the fly, without resetting 
1992:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         the ADC.
1993:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         The setting of these parameters is conditioned to ADC state.
1994:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         For parameters constraints, see comments of structure 
1995:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   *         "ADC_ChannelConfTypeDef".
1996:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @param  hadc: ADC handle
1997:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @param  sConfig: Structure of ADC channel for regular group.
1998:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   * @retval HAL status
1999:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   */
2000:./f103/HAL/Src/stm32f1xx_hal_adc.c **** HAL_StatusTypeDef HAL_ADC_ConfigChannel(ADC_HandleTypeDef* hadc, ADC_ChannelConfTypeDef* sConfig)
2001:./f103/HAL/Src/stm32f1xx_hal_adc.c **** { 
2002:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   HAL_StatusTypeDef tmp_hal_status = HAL_OK;
2003:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   __IO uint32_t wait_loop_index = 0U;
