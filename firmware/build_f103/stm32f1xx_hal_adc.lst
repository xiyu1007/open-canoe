1732:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       }
1733:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     }
1734:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   }
1735:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   
1736:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Process unlocked */
1737:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   __HAL_UNLOCK(hadc);
1738:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     
1739:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   /* Return function status */
1740:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   return tmp_hal_status;
1741:./f103/HAL/Src/stm32f1xx_hal_adc.c **** }
