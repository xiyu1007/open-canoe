2084:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       
2085:./f103/HAL/Src/stm32f1xx_hal_adc.c ****       tmp_hal_status = HAL_ERROR;
2086:./f103/HAL/Src/stm32f1xx_hal_adc.c ****     }
2087:./f103/HAL/Src/stm32f1xx_hal_adc.c ****   }
