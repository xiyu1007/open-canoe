 242:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         *PageError = 0xFFFFFFFFU;
 243:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         
 244:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         /* Erase by page by page to be done*/
 245:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         for(address = pEraseInit->PageAddress;
 246:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****             address < (pEraseInit->PageAddress + (pEraseInit->NbPages)*FLASH_PAGE_SIZE);
 247:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****             address += FLASH_PAGE_SIZE)
 248:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         {
 249:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****           FLASH_PageErase(address);
 250:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****           
 251:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****           /* Wait for last operation to be completed */
