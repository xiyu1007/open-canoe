 320:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 321:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   /* If procedure already ongoing, reject the next one */
 322:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   if (pFlash.ProcedureOnGoing != FLASH_PROC_NONE)
 323:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   {
