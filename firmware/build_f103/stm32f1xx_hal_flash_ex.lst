 327:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   /* Check the parameters */
 328:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   assert_param(IS_FLASH_TYPEERASE(pEraseInit->TypeErase));
 329:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
