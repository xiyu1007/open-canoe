 382:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** /**
 383:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   * @brief  Erases the FLASH option bytes.
 384:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   * @note   This functions erases all option bytes except the Read protection (RDP).
 385:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   *         The function @ref HAL_FLASH_Unlock() should be called before to unlock the FLASH interf
 386:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   *         The function @ref HAL_FLASH_OB_Unlock() should be called before to unlock the options b
 387:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   *         The function @ref HAL_FLASH_OB_Launch() should be called after to force the reload of t
 388:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   *         (system reset will occur)
 389:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   * @retval HAL status
 390:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   */
 391:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 392:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** HAL_StatusTypeDef HAL_FLASHEx_OBErase(void)
 393:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** {
 394:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   uint8_t rdptmp = OB_RDP_LEVEL_0;
 395:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   HAL_StatusTypeDef status = HAL_ERROR;
 396:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 397:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   /* Get the actual read protection Option Byte value */
 398:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   rdptmp = FLASH_OB_GetRDP();
 399:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 400:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   /* Wait for last operation to be completed */
 401:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   status = FLASH_WaitForLastOperation((uint32_t)FLASH_TIMEOUT_VALUE);
 402:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 403:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   if(status == HAL_OK)
 404:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   {
 405:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     /* Clean the error context */
 406:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     pFlash.ErrorCode = HAL_FLASH_ERROR_NONE;
 407:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 408:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     /* If the previous operation is completed, proceed to erase the option bytes */
 409:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     SET_BIT(FLASH->CR, FLASH_CR_OPTER);
 410:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     SET_BIT(FLASH->CR, FLASH_CR_STRT);
 411:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 412:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     /* Wait for last operation to be completed */
 413:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     status = FLASH_WaitForLastOperation((uint32_t)FLASH_TIMEOUT_VALUE);
 414:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 415:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     /* If the erase operation is completed, disable the OPTER Bit */
 416:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     CLEAR_BIT(FLASH->CR, FLASH_CR_OPTER);
 417:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 418:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     if(status == HAL_OK)
 419:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     {
 420:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****       /* Restore the last read protection Option Byte value */
 421:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****       status = FLASH_OB_RDP_LevelConfig(rdptmp);
 422:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     }
 423:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   }
 424:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 425:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   /* Return the erase status */
 426:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   return status;
 427:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** }
 428:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
