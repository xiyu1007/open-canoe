 117:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** /** @defgroup FLASHEx_Exported_Functions_Group1 FLASHEx Memory Erasing functions
 118:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****  *  @brief   FLASH Memory Erasing functions
 119:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   *
 120:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** @verbatim   
 121:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   ==============================================================================
 122:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****                 ##### FLASH Erasing Programming functions ##### 
 123:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   ==============================================================================
 124:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 125:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     [..] The FLASH Memory Erasing functions, includes the following functions:
 126:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     (+) HAL_FLASHEx_Erase: return only when erase has been done
 127:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     (+) HAL_FLASHEx_Erase_IT: end of erase is done when HAL_FLASH_EndOfOperationCallback 
 128:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         is called with parameter 0xFFFFFFFF
 129:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 130:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     [..] Any operation of erase should follow these steps:
 131:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     (#) Call the HAL_FLASH_Unlock() function to enable the flash control register and 
 132:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         program memory access.
 133:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     (#) Call the desired function to erase page.
 134:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     (#) Call the HAL_FLASH_Lock() to disable the flash program memory access 
 135:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****        (recommended to protect the FLASH memory against possible unwanted operation).
 136:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 137:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** @endverbatim
 138:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   * @{
 139:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   */
 140:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   
 141:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 142:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** /**
 143:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   * @brief  Perform a mass erase or erase the specified FLASH memory pages
 144:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   * @note   To correctly run this function, the @ref HAL_FLASH_Unlock() function
 145:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   *         must be called before.
 146:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   *         Call the @ref HAL_FLASH_Lock() to disable the flash memory access 
ARM GAS  C:\WINDOWS\ccP6mTSD.s 			page 4


 147:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   *         (recommended to protect the FLASH memory against possible unwanted operation)
 148:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   * @param[in]  pEraseInit pointer to an FLASH_EraseInitTypeDef structure that
 149:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   *         contains the configuration information for the erasing.
 150:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   *
 151:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   * @param[out]  PageError pointer to variable  that
 152:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   *         contains the configuration information on faulty page in case of error
 153:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   *         (0xFFFFFFFF means that all the pages have been correctly erased)
 154:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   *
 155:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   * @retval HAL_StatusTypeDef HAL Status
 156:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   */
 157:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** HAL_StatusTypeDef HAL_FLASHEx_Erase(FLASH_EraseInitTypeDef *pEraseInit, uint32_t *PageError)
 158:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** {
 159:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   HAL_StatusTypeDef status = HAL_ERROR;
 160:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   uint32_t address = 0U;
 161:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 162:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   /* Process Locked */
 163:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   __HAL_LOCK(&pFlash);
 164:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 165:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   /* Check the parameters */
 166:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   assert_param(IS_FLASH_TYPEERASE(pEraseInit->TypeErase));
 167:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** 
 168:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   if (pEraseInit->TypeErase == FLASH_TYPEERASE_MASSERASE)
 169:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****   {
 170:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** #if defined(FLASH_BANK2_END)
 171:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     if (pEraseInit->Banks == FLASH_BANK_BOTH)
 172:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     {
 173:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****       /* Mass Erase requested for Bank1 and Bank2 */
 174:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****       /* Wait for last operation to be completed */
 175:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****       if ((FLASH_WaitForLastOperation((uint32_t)FLASH_TIMEOUT_VALUE) == HAL_OK) && \
 176:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****           (FLASH_WaitForLastOperationBank2((uint32_t)FLASH_TIMEOUT_VALUE) == HAL_OK))
 177:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****       {
 178:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         /*Mass erase to be done*/
 179:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         FLASH_MassErase(FLASH_BANK_BOTH);
 180:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         
 181:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         /* Wait for last operation to be completed */
 182:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         if ((FLASH_WaitForLastOperation((uint32_t)FLASH_TIMEOUT_VALUE) == HAL_OK) && \
 183:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****             (FLASH_WaitForLastOperationBank2((uint32_t)FLASH_TIMEOUT_VALUE) == HAL_OK))
 184:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         {
 185:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****           status = HAL_OK;
 186:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         }
 187:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         
 188:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         /* If the erase operation is completed, disable the MER Bit */
 189:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         CLEAR_BIT(FLASH->CR, FLASH_CR_MER);
 190:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         CLEAR_BIT(FLASH->CR2, FLASH_CR2_MER);
 191:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****       }
 192:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     }
 193:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     else if (pEraseInit->Banks == FLASH_BANK_2)
 194:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     {
 195:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****       /* Mass Erase requested for Bank2 */
 196:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****       /* Wait for last operation to be completed */
 197:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****       if (FLASH_WaitForLastOperationBank2((uint32_t)FLASH_TIMEOUT_VALUE) == HAL_OK)
 198:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****       {
 199:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         /*Mass erase to be done*/
 200:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         FLASH_MassErase(FLASH_BANK_2);
 201:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         
 202:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         /* Wait for last operation to be completed */
 203:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         status = FLASH_WaitForLastOperationBank2((uint32_t)FLASH_TIMEOUT_VALUE);
ARM GAS  C:\WINDOWS\ccP6mTSD.s 			page 5


 204:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         
 205:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         /* If the erase operation is completed, disable the MER Bit */
 206:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         CLEAR_BIT(FLASH->CR2, FLASH_CR2_MER);
 207:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****       }
 208:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     }
 209:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     else 
 210:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c **** #endif /* FLASH_BANK2_END */
 211:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****     {
 212:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****       /* Mass Erase requested for Bank1 */
