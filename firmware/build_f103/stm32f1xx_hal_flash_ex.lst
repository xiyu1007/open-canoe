 214:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****       if (FLASH_WaitForLastOperation((uint32_t)FLASH_TIMEOUT_VALUE) == HAL_OK)
 215:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****       {
 216:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         /*Mass erase to be done*/
 217:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         FLASH_MassErase(FLASH_BANK_1);
 218:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         
 219:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         /* Wait for last operation to be completed */
 220:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         status = FLASH_WaitForLastOperation((uint32_t)FLASH_TIMEOUT_VALUE);
 221:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         
 222:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         /* If the erase operation is completed, disable the MER Bit */
 223:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****         CLEAR_BIT(FLASH->CR, FLASH_CR_MER);
 224:./f103/HAL/Src/stm32f1xx_hal_flash_ex.c ****       }
